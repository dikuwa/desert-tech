{
  "name": "desert-tech",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/bootstrap-system-users.ts && next dev",
    "build": "prisma generate --config=prisma.config.ts && next build",
    "start": "tsx scripts/bootstrap-system-users.ts && next start",
    "lint": "next lint",
    "postinstall": "prisma generate --config=prisma.config.ts 2>/dev/null || true",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --config=prisma.config.ts",
    "db:seed": "tsx prisma/seed.ts",
    "users:bootstrap": "tsx scripts/bootstrap-system-users.ts",
    "db:reset": "prisma db push --force-reset --config=prisma.config.ts && tsx prisma/seed.ts",
    "db:studio": "prisma studio --config=prisma.config.ts",
    "sku:repair": "tsx scripts/repair-product-sku-prefixes.ts",
    "sku:repair:apply": "tsx scripts/repair-product-sku-prefixes.ts --apply"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1060.0",
    "@aws-sdk/s3-request-presigner": "^3.1060.0",
    "@better-auth/infra": "^0.2.11",
    "@better-auth/prisma-adapter": "^1.6.14",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.0.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@react-email/components": "^1.0.12",
    "@react-pdf/renderer": "^4.0.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.0.0",
    "@upstash/redis": "^1.34.0",
    "better-auth": "^1.6.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^4.0.0",
    "dotenv": "^16.4.0",
    "framer-motion": "^12.0.0",
    "input-otp": "^1.4.0",
    "kysely": "^0.29.2",
    "lucide-react": "^0.460.0",
    "next": "16.2.7",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-dropzone": "^15.0.0",
    "react-email": "^6.5.0",
    "react-hook-form": "^7.54.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4",
    "uuid": "^14.0.0",
