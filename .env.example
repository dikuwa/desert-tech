# ===========================================
# Desert Technology Consultant — Environment
# ===========================================

# --- Database (Neon PostgreSQL for production, leave empty for dev mode) ---
# Get your connection string from Neon dashboard: https://console.neon.tech
# Example: postgresql://user:pass@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Leave EMPTY for dev mode (uses in-memory mock data, no auth required).
DATABASE_URL=

# --- Better Auth (only needed in production) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Optional overrides for the three automatically bootstrapped system users.
# Leave unset to use the documented initial credentials.
# DESERTTECH_OWNER_PASSWORD=
# DESERTTECH_ADMIN_PASSWORD=
# DESERTTECH_STAFF_PASSWORD=

# --- Store Contact Info ---
NEXT_PUBLIC_STORE_WHATSAPP=264852775140
NEXT_PUBLIC_STORE_PHONE=+264852775140
NEXT_PUBLIC_STORE_EMAIL=info@deserttechnology.com.na

# --- Resend (for transactional emails) ---
# Get your API key from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxx
#
# Sender email configuration:
#   RESEND_FROM_EMAIL — Must be a verified sender in your Resend account.
#     If you verified deserttechnology.com.na in Resend, use:
#     RESEND_FROM_EMAIL=noreply@deserttechnology.com.na
#     If using a different verified domain, set it here.
#
#   RESEND_REPLY_TO_EMAIL — Where customer replies go.
#     Defaults to BUSINESS_EMAIL if not set.
#
#   BUSINESS_EMAIL — Fallback if RESEND_FROM_EMAIL is not set.
#
# Example:
#   RESEND_FROM_EMAIL=info@desertechnam.com
#   RESEND_REPLY_TO_EMAIL=sales@desertechnam.com
#   BUSINESS_EMAIL=sales@desertechnam.com
# RESEND_FROM_EMAIL=
# RESEND_REPLY_TO_EMAIL=
# BUSINESS_EMAIL=

# --- Public App URL (for email links, shared documents) ---
# Set to your production domain when deployed.
# In dev mode, defaults to http://localhost:3000.
NEXT_PUBLIC_APP_URL=https://deserttechnology.com.na

# --- Upstash Redis (for Better Auth session caching) ---
# Optional: improves performance by caching sessions
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Cloudflare R2 (product images and generated documents) ---
# CLOUDFLARE_R2_ENDPOINT=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=
# CLOUDFLARE_R2_PUBLIC_DEV_URL=
