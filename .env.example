# Database - PostgreSQL (Neon/Supabase)
DATABASE_URL="postgres://user:password@host:5432/desert-tech"

# Cache - Upstash Redis
UPSTASH_REDIS_URL="https://your-id.upstash.io"
UPSTASH_REDIS_TOKEN="your-redis-token"

# Auth - Better Auth
BETTER_AUTH_SECRET="generate-a-32-char-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Email - Resend
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="noreply@deserttechnology.com.na"

# File Storage - Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY_ID="your-r2-access-key"
CLOUDFLARE_R2_SECRET_ACCESS_KEY="your-r2-secret-key"
CLOUDFLARE_R2_ENDPOINT="https://your-account.r2.cloudflarestorage.com"
CLOUDFLARE_R2_BUCKET_NAME="desert-tech"
CLOUDFLARE_R2_PUBLIC_DEV_URL="https://pub-xxxxx.r2.dev"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STORE_PHONE="+264811234567"
NEXT_PUBLIC_STORE_WHATSAPP="+264811234567"
